package ${target.javaPackageFromFolder(${SRC})};

import ${ROOT_PKG}.rest.dto.generic.GenericDTO;
import lombok.Data;
import lombok.EqualsAndHashCode;
import lombok.NoArgsConstructor;
import lombok.ToString;
#foreach( $import in $java.imports($entity) )
import $import;
#end

/**
 * Flat DTO class for "${entity.name}".
 *
 * This type is the minimal transport representation of the entity for API boundaries.
 * It extends #[[{@link GenericDTO}]]# and follows a strict flat-mapping policy to keep
 * payloads predictable, small, and free of recursive graphs.
 *
 * Mapping philosophy:
 * <ul>
 *   <li>Include all primary key attributes.</li>
 *   <li>Include only scalar/simple non-key attributes (primitive types, wrappers,
 *       #[[{@link String}]]#, common numeric/date-time value types).</li>
 *   <li>Exclude domain object references, arrays, collections and relationship links.</li>
 *   <li>Do not traverse associations; no nested DTOs are generated in Flat DTOs.</li>
 * </ul>
 *
 * Why this design:
 * <ul>
 *   <li>Prevents infinite self-containment and cyclic serialization chains.</li>
 *   <li>Produces stable and easy-to-consume JSON contracts for endpoints.</li>
 *   <li>Improves performance by reducing payload size and serialization depth.</li>
 *   <li>Provides a safe base representation that Deep DTOs can reuse as nested values.</li>
 * </ul>
 *
 * Lombok integration:
 * <ul>
 *   <li>#[[{@link lombok.Data}]]# generates accessors and utility methods.</li>
 *   <li>#[[{@link lombok.NoArgsConstructor}]]# provides a no-args constructor.</li>
 *   <li>#[[{@link lombok.EqualsAndHashCode}]]# and #[[{@link lombok.ToString}]]#
 *       include parent state through #[[{@code callSuper = true}]]#.</li>
 * </ul>
 *
 * @category DTO
 * @version 1.0.0
 * @see GenericDTO
 * @author Telosys
 *
 */
@Data
@NoArgsConstructor
@EqualsAndHashCode(callSuper = true)
@ToString(callSuper = true)
public class ${dtoFlatClass} extends GenericDTO {

    //--- PRIMARY KEY 
#foreach( $attribute in $entity.keyAttributes )
    private $attribute.type $attribute.name #if($attribute.hasInitialValue())= ${attribute.initialValue} #end;
#end
    //--- OTHER DATA FIELDS 
#foreach( $attribute in $entity.nonKeyAttributes )
#set( $t = $attribute.type )
#if( $t == "boolean" || $t == "byte" || $t == "short" || $t == "int" || $t == "long" || $t == "float" || $t == "double" || $t == "char" || $t == "Boolean" || $t == "Byte" || $t == "Short" || $t == "Integer" || $t == "Long" || $t == "Float" || $t == "Double" || $t == "Character" || $t == "String" || $t == "BigDecimal" || $t == "BigInteger" || $t == "LocalDate" || $t == "LocalDateTime" || $t == "LocalTime" || $t == "OffsetDateTime" || $t == "ZonedDateTime" || $t == "Instant" || $t == "Date" || $t == "Timestamp" || $t == "Time" || $t == "UUID" )
    private $attribute.type $attribute.name #if($attribute.hasInitialValue())= ${attribute.initialValue} #end;
#end
#end
}
