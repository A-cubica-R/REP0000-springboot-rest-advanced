#if ( $entity.isJoinEntity() )
#cancel("No DTO class for join entity")
#end
## --------------------------------------------------
#checkId($entity)
#parse("include/init_var_entity.vm")
#parse("include/java_header.vm")
##---------------------------------------------------------------------------------------
#macro( dtoType $link )
$link.fieldType.replace($link.targetEntitySimpleType, "${link.targetEntitySimpleType}FlatDTO")#end
