package ${target.javaPackageFromFolder(${SRC})};

import ${ROOT_PKG}.rest.dto.generic.GenericDTO;
import lombok.Data;
import lombok.EqualsAndHashCode;
import lombok.NoArgsConstructor;
import lombok.ToString;
#foreach( $import in $java.imports($entity) )
import $import;
#end

/**
 * Deep DTO class for "${entity.name}".
 *
 * This type is an enriched transport representation for API boundaries.
 * It extends #[[{@link GenericDTO}]]# and follows a controlled deep-mapping policy:
 * relationships are allowed, but nested values are always represented as Flat DTOs.
 *
 * Mapping philosophy:
 * <ul>
 *   <li>Include all primary key attributes.</li>
 *   <li>Include scalar/simple non-key attributes (same base values used by Flat DTOs).</li>
 *   <li>Include relationship fields (links), but map them exclusively to
 *       #[[{@code *FlatDTO}]]# types (single references and collections).</li>
 *   <li>Do not embed #[[{@code *DeepDTO}]]# inside #[[{@code *DeepDTO}]]#; nested deep graphs are forbidden.</li>
 * </ul>
 *
 * Why this design:
 * <ul>
 *   <li>Preserves domain context by exposing associations when needed by endpoints.</li>
 *   <li>Prevents infinite self-containment and cyclic deep serialization.</li>
 *   <li>Keeps JSON structures bounded, predictable and easier to consume.</li>
 *   <li>Balances expressiveness (relations present) with safety (Flat-only nesting).</li>
 * </ul>
 *
 * Lombok integration:
 * <ul>
 *   <li>#[[{@link lombok.Data}]]# generates accessors and utility methods.</li>
 *   <li>#[[{@link lombok.NoArgsConstructor}]]# provides a no-args constructor.</li>
 *   <li>#[[{@link lombok.EqualsAndHashCode}]]# and #[[{@link lombok.ToString}]]#
 *       include parent state through #[[{@code callSuper = true}]]#.</li>
 * </ul>
 *
 * @category DTO
 * @version 1.0.0
 * @see GenericDTO
 * @author Telosys
 *
 */
@Data
@NoArgsConstructor
@EqualsAndHashCode(callSuper = true)
@ToString(callSuper = true)
public class ${dtoDeepClass} extends GenericDTO {

    //--- PRIMARY KEY 
#foreach( $attribute in $entity.keyAttributes )
    private $attribute.type $attribute.name #if($attribute.hasInitialValue())= ${attribute.initialValue} #end;
#end
    //--- OTHER DATA FIELDS 
#foreach( $attribute in $entity.nonKeyAttributes )
    private $attribute.type $attribute.name #if($attribute.hasInitialValue())= ${attribute.initialValue} #end;
#end
#if ( $entity.hasLinks() )	
    //--- LINKS ( RELATIONSHIPS )
#foreach( $link in $entity.links )
    private #dtoType($link) $link.fieldName ; 
#end
#end
}
