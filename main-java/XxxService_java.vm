package ${target.javaPackageFromFolder(${SRC})};

import java.util.List;
#foreach( $import in $java.imports($entity.keyAttributes) )
import $import;
#end
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;
import ${ROOT_PKG}.persistence.entities.${jpaEntityClass};
import ${ROOT_PKG}.persistence.repositories.${repositoryClass};
import ${ROOT_PKG}.rest.dto.flat.${entity.name}DTOFlat;
import ${ROOT_PKG}.rest.dto.deep.${entity.name}DTODeep;
import ${ROOT_PKG}.rest.services.commons.GenericService;

/**
 * REST service for entity "${entity.name}" <br>
 *
 * @author Telosys
 */
@Service
@Transactional
public class ${serviceClass} extends GenericService<${jpaEntityClass}, ${entity.name}DTOFlat, ${entity.name}DTODeep> {

    @Autowired
    private ${repositoryClass} repository;

    public ${serviceClass}() {
        super(${jpaEntityClass}.class, ${entity.name}DTOFlat.class, ${entity.name}DTODeep.class);
    }

    @Transactional(readOnly = true)
    public List<${entity.name}DTODeep> findAll() {
        return entityListToDtoList(repository.findAll());
    }

    @Transactional(readOnly = true)
    public ${entity.name}DTODeep findById(${entity.keyAttribute.type} ${entity.keyAttribute.name}) {
        return entityToDto(repository.findById(${entity.keyAttribute.name}));
    }

    public ${entity.name}DTODeep create(${entity.name}DTOFlat dto) {
#if ($entity.hasAutoIncrementedKey())
        return entityToDto(repository.save(dtoToEntity(dto)));
#else
        if (repository.existsById(dto.${entity.keyAttribute.getter}())) {
            throw new RuntimeException("${entity.name} ya existe con id: " + dto.${entity.keyAttribute.getter}());
        }
        return entityToDto(repository.save(dtoToEntity(dto)));
#end
    }

    public ${entity.name}DTODeep update(${entity.keyAttribute.type} ${entity.keyAttribute.name}, ${entity.name}DTOFlat dto) {
        repository.findById(${entity.keyAttribute.name})
                .orElseThrow(() -> new RuntimeException("${entity.name} no encontrado con id: " + ${entity.keyAttribute.name}));
        dto.${entity.keyAttribute.setter}(${entity.keyAttribute.name});
        return entityToDto(repository.save(dtoToEntity(dto)));
    }

    public void deleteById(${entity.keyAttribute.type} ${entity.keyAttribute.name}) {
        repository.findById(${entity.keyAttribute.name})
                .orElseThrow(() -> new RuntimeException("${entity.name} no encontrado con id: " + ${entity.keyAttribute.name}));
        repository.deleteById(${entity.keyAttribute.name});
    }
}